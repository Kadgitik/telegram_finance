BOT_TOKEN=your_telegram_bot_token
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=finance_bot
WEBHOOK_URL=https://finance-bot-7pf0.onrender.com
# Базова HTTPS URL Mini App (якщо порожньо — те саме, що WEBHOOK_URL)
WEBAPP_URL=
WEBHOOK_SECRET=generate_random_string_at_least_16_chars
# Fernet-ключ для шифрування Monobank токенів у БД. Згенерувати:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Секрет у шляху Mono webhook. Якщо порожній — деривується з WEBHOOK_SECRET автоматично.
MONO_WEBHOOK_SECRET=
# Локально: любой свободный порт. На Render PORT задаёт платформа — не прописывайте вручную.
PORT=10000
